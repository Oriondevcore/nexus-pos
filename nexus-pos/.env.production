# Firebase Configuration (Production)
VITE_FIREBASE_API_KEY=your_production_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_production_firebase_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_production_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_production_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_production_firebase_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_production_firebase_app_id_here

# Yoco Payment Integration (Production)
VITE_YOCO_PUBLIC_KEY=your_production_yoco_public_key_here
VITE_YOCO_PAYMENT_LINK_URL=https://pay.yoco.com/your_production_merchant_id

# Production Environment
VITE_APP_ENV=production
VITE_API_BASE_URL=https://api.yourdomain.com
VITE_FIREBASE_FUNCTION_URL=https://us-central1-your_production_project.cloudfunctions.net

# NOTE: VITE_YOCO_SECRET_KEY is NOT stored in this .env
# In production, the secret key is:
# 1. Stored as a Firebase Cloud Function environment variable
# 2. Protected by Firebase authentication and authorization
# 3. Used server-side only for payment processing
# 4. Never exposed to the client application
